{
  "name": "teambrain",
  "version": "0.2.1",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "test": "vitest run",
    "test:changed": "vitest run --changed",
    "test:integration": "vitest run integration",
    "lint": "eslint . && prettier --check .",
    "bench": "pnpm -r --if-present run bench"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@teambrain/cli": "workspace:*",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.0.2"
  }
}
