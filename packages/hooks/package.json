{
  "name": "@teambrain/hooks",
  "version": "0.3.0",
  "description": "TeamBrain capture adapters: agent tool events → redacted, metadata-only session records",
  "keywords": [
    "ai",
    "agents",
    "hooks",
    "claude-code",
    "cursor",
    "telemetry"
  ],
  "homepage": "https://github.com/donatienmigue/TeamBrain#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donatienmigue/TeamBrain.git",
    "directory": "packages/hooks"
  },
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "@teambrain/core": "workspace:*",
    "@teambrain/mcp": "workspace:*",
    "@teambrain/redact": "workspace:*",
    "zod": "^4.4.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cursor": {
      "types": "./dist/cursor/index.d.ts",
      "import": "./dist/cursor/index.js"
    }
  }
}
